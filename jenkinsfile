pipeline{
    agent any
    tools {
        jdk 'jdk17'
        maven 'maven39'
        allure 'allure'
    }
    stages {
        stage('pull code'){
            steps{
                git url: 'https://github.com/adle129/api_automation.git', branch: 'main'
            }
        }
        stage('Maven create and execute testing'){
            steps {
                sh 'mvn clean test'
            }

        }
        stage('Generate Allure report'){
            steps{
                allure includeProperties: false, jdk: 'jdk17', results:[[path: 'allure-results']]
            }
        }
    }
    post {
        always {
            allure includeProperties: false, jdk: 'jdk17', results: [[path: 'allure-results']]
        }
    }




}