pipeline {
    agent any
    tools {
        jdk 'jdk17'
        maven 'maven3'
        allure 'allure'
    }
    stages {
        stage('Test') {
            steps {
                sh 'mvn clean test'
            }
        }
        stage('Report') {
            steps {
                allure results: [[path: 'allure-results']]
            }
        }
    }
    post {
        always {
            allure results: [[path: 'allure-results']]
        }
    }
}